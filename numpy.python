{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyMoupEG8W3V4kjPvFyFjslo"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","execution_count":1,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"fZOXxPouuvc6","executionInfo":{"status":"ok","timestamp":1779598497900,"user_tz":-330,"elapsed":27715,"user":{"displayName":"Priya Singh","userId":"06087557203111795000"}},"outputId":"66ad2598-bc87-48c2-b2ce-b061537db619"},"outputs":[{"output_type":"stream","name":"stdout","text":["Pure Python version 25.3336\n","Numpy version 0.7228\n","Numpy is in this example 35.0516 times faster!\n"]}],"source":["import time\n","import numpy as np\n","\n","size_of_vec = 100000000\n","\n","def pure_python_version():                                                # This function will return the time for python calculation\n","    time_python = time.time()                                             # Start time before operation\n","    my_list1 = range(size_of_vec)                                         # Creating a list with 1000000 values\n","    my_list2 = range(size_of_vec)\n","    sum_list = [my_list1[i] + my_list2[i] for i in range(len(my_list1))]  # Calculating the sum\n","    return time.time() - time_python                                      # Return Current time - start time\n","\n","def numpy_version():                                                      # This function will return the time for numpy calculation\n","    time_numpy = time.time()                                              # Start time before operation\n","    my_arr1 = np.arange(size_of_vec)                                      # Creating a numpy array of 1000000 values\n","    my_arr2 = np.arange(size_of_vec)\n","    sum_array = my_arr1 + my_arr2                                         # Calculate the sum\n","    return time.time() - time_numpy                                       # Return current time - start time\n","\n","\n","python_time = pure_python_version()                                       # Time taken for Python expression\n","numpy_time = numpy_version()                                              # Time taken for numpy operation\n","print(\"Pure Python version {:0.4f}\".format(python_time))\n","print(\"Numpy version {:0.4f}\".format(numpy_time))\n","print(\"Numpy is in this example {:0.4f} times faster!\".format(python_time/numpy_time))"]},{"cell_type":"code","source":["import numpy as np"],"metadata":{"id":"Z06ARmm4wnxH","executionInfo":{"status":"ok","timestamp":1779598497905,"user_tz":-330,"elapsed":2,"user":{"displayName":"Priya Singh","userId":"06087557203111795000"}}},"execution_count":2,"outputs":[]},{"cell_type":"code","source":["my_list = [1,2,3,4,5]\n","my_list\n","print(my_list)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"4voNNkcYxYVD","executionInfo":{"status":"ok","timestamp":1779598497918,"user_tz":-330,"elapsed":11,"user":{"displayName":"Priya Singh","userId":"06087557203111795000"}},"outputId":"63db765d-e94b-4ef8-f016-504836426b33"},"execution_count":3,"outputs":[{"output_type":"stream","name":"stdout","text":["[1, 2, 3, 4, 5]\n"]}]},{"cell_type":"code","source":["type(my_list)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"lWQKSaZdxtpU","executionInfo":{"status":"ok","timestamp":1779598497927,"user_tz":-330,"elapsed":8,"user":{"displayName":"Priya Singh","userId":"06087557203111795000"}},"outputId":"8159f9f6-ecb6-4cf0-8340-ab880884674c"},"execution_count":4,"outputs":[{"output_type":"execute_result","data":{"text/plain":["list"]},"metadata":{},"execution_count":4}]},{"cell_type":"code","source":["arr = np.array(my_list)\n","arr\n","print(arr)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"IrOY_3vGx20D","executionInfo":{"status":"ok","timestamp":1779598497936,"user_tz":-330,"elapsed":8,"user":{"displayName":"Priya Singh","userId":"06087557203111